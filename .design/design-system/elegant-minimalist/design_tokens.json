{
  "version": {
    "$type": "string",
    "$value": "alpha"
  },
  "name": {
    "$type": "string",
    "$value": "Elegant minimalist"
  },
  "description": {
    "$type": "string",
    "$value": "A restrained personal academic website system for research, teaching, and professional credibility."
  },
  "colors": {
    "page": {
      "$type": "color",
      "$value": "#F8F6F1"
    },
    "surface": {
      "$type": "color",
      "$value": "#FFFFFF"
    },
    "surface-muted": {
      "$type": "color",
      "$value": "#F1EEE7"
    },
    "text": {
      "$type": "color",
      "$value": "#1F1F1B"
    },
    "text-muted": {
      "$type": "color",
      "$value": "#5F625C"
    },
    "border": {
      "$type": "color",
      "$value": "#D8D2C5"
    },
    "accent": {
      "$type": "color",
      "$value": "#8A2D1F"
    },
    "accent-hover": {
      "$type": "color",
      "$value": "#6F2117"
    },
    "on-accent": {
      "$type": "color",
      "$value": "#FFFFFF"
    },
    "support": {
      "$type": "color",
      "$value": "#2F5D62"
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": "56px",
        "fontWeight": 600,
        "lineHeight": 1.05,
        "letterSpacing": "0px"
      }
    },
    "headline-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": "40px",
        "fontWeight": 600,
        "lineHeight": 1.15,
        "letterSpacing": "0px"
      }
    },
    "headline-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": "30px",
        "fontWeight": 600,
        "lineHeight": 1.2,
        "letterSpacing": "0px"
      }
    },
    "title-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "22px",
        "fontWeight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "0px"
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": "20px",
        "fontWeight": 400,
        "lineHeight": 1.65,
        "letterSpacing": "0px"
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Source Serif 4",
        "fontSize": "18px",
        "fontWeight": 400,
        "lineHeight": 1.7,
        "letterSpacing": "0px"
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "15px",
        "fontWeight": 400,
        "lineHeight": 1.55,
        "letterSpacing": "0px"
      }
    },
    "label-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "15px",
        "fontWeight": 600,
        "lineHeight": 1.3,
        "letterSpacing": "0px"
      }
    },
    "label-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "14px",
        "fontWeight": 500,
        "lineHeight": 1.35,
        "letterSpacing": "0px"
      }
    },
    "label-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "12px",
        "fontWeight": 500,
        "lineHeight": 1.35,
        "letterSpacing": "0px"
      }
    },
    "caption": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": "13px",
        "fontWeight": 400,
        "lineHeight": 1.45,
        "letterSpacing": "0px"
      }
    }
  },
  "rounded": {
    "none": {
      "$type": "dimension",
      "$value": "0px"
    },
    "sm": {
      "$type": "dimension",
      "$value": "4px"
    },
    "md": {
      "$type": "dimension",
      "$value": "6px"
    },
    "full": {
      "$type": "dimension",
      "$value": "9999px"
    }
  },
  "spacing": {
    "xs": {
      "$type": "dimension",
      "$value": "4px"
    },
    "sm": {
      "$type": "dimension",
      "$value": "8px"
    },
    "md": {
      "$type": "dimension",
      "$value": "16px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "24px"
    },
    "xl": {
      "$type": "dimension",
      "$value": "32px"
    },
    "xxl": {
      "$type": "dimension",
      "$value": "48px"
    },
    "section": {
      "$type": "dimension",
      "$value": "96px"
    },
    "mobile-margin": {
      "$type": "dimension",
      "$value": "20px"
    },
    "page-margin": {
      "$type": "dimension",
      "$value": "32px"
    },
    "rail-width": {
      "$type": "dimension",
      "$value": "260px"
    },
    "content-width": {
      "$type": "dimension",
      "$value": "760px"
    },
    "site-width": {
      "$type": "dimension",
      "$value": "1180px"
    }
  },
  "components": {
    "nav-link": {
      "$type": "component",
      "$value": {
        "textColor": "{colors.text-muted}",
        "typography": "{typography.label-md}",
        "padding": "8px"
      }
    },
    "nav-link-active": {
      "$type": "component",
      "$value": {
        "textColor": "{colors.accent}",
        "typography": "{typography.label-md}",
        "padding": "8px"
      }
    },
    "button-primary": {
      "$type": "component",
      "$value": {
        "backgroundColor": "{colors.accent}",
        "textColor": "{colors.on-accent}",
        "typography": "{typography.label-lg}",
        "rounded": "{rounded.sm}",
        "padding": "12px 16px"
      }
    },
    "button-primary-hover": {
      "$type": "component",
      "$value": {
        "backgroundColor": "{colors.accent-hover}",
        "textColor": "{colors.on-accent}"
      }
    },
    "button-secondary": {
      "$type": "component",
      "$value": {
        "backgroundColor": "{colors.surface}",
        "textColor": "{colors.text}",
        "typography": "{typography.label-lg}",
        "rounded": "{rounded.sm}",
        "padding": "12px 16px"
      }
    },
    "research-entry": {
      "$type": "component",
      "$value": {
        "backgroundColor": "{colors.surface}",
        "textColor": "{colors.text}",
        "typography": "{typography.body-sm}",
        "rounded": "{rounded.md}",
        "padding": "24px"
      }
    },
    "lecture-row": {
      "$type": "component",
      "$value": {
        "backgroundColor": "{colors.surface}",
        "textColor": "{colors.text}",
        "typography": "{typography.body-sm}",
        "rounded": "{rounded.none}",
        "padding": "16px 0px"
      }
    },
    "tag": {
      "$type": "component",
      "$value": {
        "backgroundColor": "{colors.surface-muted}",
        "textColor": "{colors.text-muted}",
        "typography": "{typography.label-sm}",
        "rounded": "{rounded.full}",
        "padding": "4px 8px"
      }
    },
    "callout": {
      "$type": "component",
      "$value": {
        "backgroundColor": "{colors.surface-muted}",
        "textColor": "{colors.text}",
        "typography": "{typography.body-sm}",
        "rounded": "{rounded.md}",
        "padding": "24px"
      }
    }
  }
}
